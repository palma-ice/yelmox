FC = gfortran 

INC_NC = -I/usr/include
LIB_NC = -L/usr/lib/x86_64-linux-gnu -lnetcdff -Wl,-Bsymbolic-functions -flto=auto -ffat-lto-objects -flto=auto -Wl,-z,relro -Wl,-z,now -lnetcdf -lnetcdf -lm 

YELMOROOT = /home/javier/Models/yelmo-ucm/yelmo
INC_YELMO = -I${YELMOROOT}/libyelmo/include 
LIB_YELMO = -L${YELMOROOT}/libyelmo/include -lyelmo

LISROOT = /home/javier/Models/dependencies/lis
INC_LIS = -I${LISROOT}/include 
LIB_LIS = -L${LISROOT}/lib/ -llis

FFTWROOT = /home/javier/Models/dependencies/fftw
INC_FFTW = -I${FFTWROOT}/include
LIB_FFTW = -L${FFTWROOT}/lib -lfftw3 -lm

ISOSTASYROOT = /home/javier/Models/yelmo-ucm/isostasy
INC_ISOSTASY = -I$(ISOSTASYROOT)/libisostasy/include
LIB_ISOSTASY = -L${ISOSTASYROOT}/libisostasy/include -lisostasy

FFLAGS = -I$(objdir) -J$(objdir) -m64 -ffree-line-length-none 
LFLAGS  = $(LIB_NC) $(LIB_YELMO) $(LIB_LIS) $(LIB_FFTW) $(LIB_ISOSTASY) -Wl,-zmuldefs

DFLAGS_NODEBUG = -O2
DFLAGS_DEBUG   = -w -g -p -ggdb -ffpe-trap=invalid,zero,overflow -fbacktrace -fcheck=all -Wp,-DDEBUG
DFLAGS_PROFILE = -O2 -p -ggdb
